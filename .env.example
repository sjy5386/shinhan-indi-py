# INDI 자격 증명 — 절대 커밋하지 말 것 (.env 는 gitignore 됨)

# 신한투자증권 ID / PW
INDI_ID=your_id
INDI_PW=your_password

# 공동인증서 비밀번호 — 비워두면 시세조회 전용 모드 (잔고는 보통 가능, 주문은 불가)
INDI_CERT_PW=

# 계좌 비밀번호 (모든 등록 계좌에 동일하게 적용. 다르면 별도 처리 필요)
INDI_ACCOUNT_PW=your_account_password

# (선택) 특정 계좌 하나만 분석할 때만. 비워두면 전체 계좌 enumerate.
INDI_ACCOUNT_NO=

# INDI Starter 경로
INDI_STARTER_PATH=C:\SHINHAN-i\indi\giexpertstarter.exe

# OCX ProgID
#   x86 / ARM64 Windows 권장: GIEXPERTCONTROL.GiExpertControlCtrl.1 (이미 등록됨, 32bit Python 필요)
#   x64 Windows 전용:        GIEXPERTCONTROL6.GIExpertControl6Ctrl.1 (regsvr32 등록 필요)
INDI_PROGID=GIEXPERTCONTROL.GiExpertControlCtrl.1
